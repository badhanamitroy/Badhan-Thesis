    "# Category prediction with confidence\n",
    "# =========================================\n",
    "\n",
    "def predict_category_with_confidence(model, X_input, encoder):\n",
    "    probs = model.predict_proba(X_input)\n",
    "    top_idx = probs.argmax(axis=1)[0]\n",
    "    confidence = probs.max(axis=1)[0]\n",
    "    category_name = encoder.inverse_transform([top_idx])[0]\n",
    "    return category_name, confidence, probs"
   ]
  },
