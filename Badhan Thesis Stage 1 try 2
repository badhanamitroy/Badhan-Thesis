    "# Final hierarchical router\n",
    "# ================================\n",
    "\n",
    "def hierarchical_predict(\n",
    "    X_input,\n",
    "    category_model,\n",
    "    category_encoder,\n",
    "    category_models,\n",
    "    threshold=0.75,\n",
    "    top_k_diseases=3,\n",
    "    fallback_top_categories=2\n",
    "):\n",
    "    pred_category, cat_conf, cat_probs = predict_category_with_confidence(\n",
    "        category_model,\n",
    "        X_input,\n",
    "        category_encoder\n",
    "    )\n",
    "\n",
    "    output = {\n",
    "        \"predicted_category\": pred_category,\n",
    "        \"category_confidence\": float(cat_conf),\n",
    "        \"disease_predictions\": []\n",
    "    }\n",
    "\n",
    "    # high-confidence route\n",
    "    if cat_conf >= threshold and pred_category in category_models:\n",
    "        info = category_models[pred_category]\n",
    "        diseases = get_top_k_diseases(\n",
    "            info[\"model\"],\n",
    "            info[\"encoder\"],\n",
    "            X_input,\n",
    "            k=top_k_diseases\n",
    "        )\n",
    "        output[\"disease_predictions\"] = [\n",
    "            {\n",
    "                \"category\": pred_category,\n",
    "                \"disease\": d,\n",
    "                \"confidence\": c\n",
    "            }\n",
    "            for d, c in diseases\n",
    "        ]\n",
    "        return output\n",
    "\n",
    "    # fallback: top-N categories\n",
    "    top_cat_indices = cat_probs[0].argsort()[-fallback_top_categories:][::-1]\n",
    "\n",
    "    fallback_results = []\n",
    "\n",
    "    for idx in top_cat_indices:\n",
    "        cat = category_encoder.inverse_transform([idx])[0]\n",
    "\n",
    "        if cat not in category_models:\n",
    "            continue\n",
    "\n",
    "        info = category_models[cat]\n",
    "        diseases = get_top_k_diseases(\n",
    "            info[\"model\"],\n",
    "            info[\"encoder\"],\n",
    "            X_input,\n",
    "            k=top_k_diseases\n",
    "        )\n",
    "\n",
    "        for d, c in diseases:\n",
    "            fallback_results.append({\n",
    "                \"category\": cat,\n",
    "                \"disease\": d,\n",
    "                \"confidence\": c,\n",
    "                \"category_probability\": float(cat_probs[0][idx])\n",
    "            })\n",
    "\n",
    "    output[\"disease_predictions\"] = fallback_results\n",
    "    return output\n"
   ]
  },
