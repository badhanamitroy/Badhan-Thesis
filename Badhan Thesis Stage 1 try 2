    "# ==============================\n",
    "# Disease Name Normalizer\n",
    "# ==============================\n",
    "\n",
    "import re\n",
    "\n",
    "def normalize_disease(text):\n",
    "    text = str(text).lower().strip()\n",
    "\n",
    "    # remove brackets (example: (ards))\n",
    "    # text = re.sub(r\"\\(.*?\\)\", \"\", text)\n",
    "\n",
    "    # remove punctuation\n",
    "    text = re.sub(r\"[^a-z0-9\\s]\", \"\", text)\n",
    "\n",
    "    # remove extra spaces\n",
    "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
    "\n",
    "    return text\n",
    "\n",
    "df = category_df.copy()\n",
    "df[\"disease_clean\"] = df[\"diseases\"].apply(normalize_disease)\n",
    "\n",
    "print(\"Unique diseases before cleaning:\", df[\"diseases\"].nunique())\n",
    "print(\"Unique diseases after cleaning :\", df[\"disease_clean\"].nunique())\n",
    "\n",
    "# Example input\n",
    "text = \"Acute Respiratory Distress Syndrome (ARDS)\"\n",
    "\n",
    "print(normalize_disease(text))"
   ]
