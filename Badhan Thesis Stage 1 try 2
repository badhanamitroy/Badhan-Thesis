    "# Train and evaluate per-category disease models properly\n",
    "# =========================================================\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from lightgbm import LGBMClassifier\n",
    "from sklearn.metrics import accuracy_score, f1_score\n",
    "\n",
    "category_models = {}\n",
    "category_reports = []\n",
    "\n",
    "category_groups = dict(tuple(df.groupby(\"category\")))\n",
    "print(\"Total categories:\", len(category_groups))\n",
    "\n",
    "for cat, sub_df in category_groups.items():\n",
    "    print(f\"\\n==============================\")\n",
    "    print(f\"Category: {cat}\")\n",
    "    print(f\"==============================\")\n",
    "\n",
    "    n_rows = len(sub_df)\n",
    "    n_diseases_raw = sub_df[\"disease_clean\"].nunique()\n",
    "\n",
    "    print(\"Rows     :\", n_rows)\n",
    "    print(\"Diseases :\", n_diseases_raw)\n",
    "\n",
    "    # -----------------------------\n",
    "    # Remove ultra-rare diseases\n",
    "    # -----------------------------\n",
    "    disease_counts = sub_df[\"disease_clean\"].value_counts()\n",
    "\n",
    "    rare_diseases = disease_counts[disease_counts < 2].index.tolist()\n",
    "\n",
    "    if len(rare_diseases) > 0:\n",
    "        print(f\"Removing {len(rare_diseases)} disease(s) with <2 samples\")\n",
    "\n",
    "    sub_df_filtered = sub_df[~sub_df[\"disease_clean\"].isin(rare_diseases)].copy()\n",
    "\n",
    "    n_rows_filtered = len(sub_df_filtered)\n",
    "    n_diseases_filtered = sub_df_filtered[\"disease_clean\"].nunique()\n",
    "\n",
    "    print(\"Rows after filtering     :\", n_rows_filtered)\n",
    "    print(\"Diseases after filtering :\", n_diseases_filtered)\n",
    "\n",
    "    if n_diseases_filtered < 2:\n",
    "        print(\"Skipped: not enough disease classes after filtering\")\n",
    "        continue\n",
    "\n",
    "    X_sub = sub_df_filtered.drop(columns=[\"Categories\", \"category\", \"diseases\", \"disease_clean\"]).copy()\n",
    "    X_sub.columns = [clean_feature_name(c) for c in X_sub.columns]\n",
    "    X_sub = X_sub.astype(\"float32\")\n",
    "\n",
    "    y_sub = sub_df_filtered[\"disease_clean\"]\n",
    "\n",
    "    disease_encoder_sub = LabelEncoder()\n",
    "    y_sub_encoded = disease_encoder_sub.fit_transform(y_sub)\n",
    "\n",
    "    # Extra safety check\n",
    "    class_counts = pd.Series(y_sub_encoded).value_counts()\n",
    "    min_class_count = class_counts.min()\n",
    "    print(\"Minimum class count after filtering:\", min_class_count)\n",
    "\n",
    "    if min_class_count < 2:\n",
    "        print(\"Skipped: still has class with <2 samples\")\n",
    "        continue\n",
    "\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X_sub,\n",
    "        y_sub_encoded,\n",
    "        test_size=0.2,\n",
    "        stratify=y_sub_encoded,\n",
    "        random_state=42\n",
    "    )\n",
    "\n",
    "    model = LGBMClassifier(\n",
    "        n_estimators=300,\n",
    "        learning_rate=0.05,\n",
    "        num_leaves=63,\n",
    "        subsample=0.8,\n",
    "        colsample_bytree=0.8,\n",
    "        random_state=42,\n",
    "        n_jobs=-1,\n",
    "        verbose=-1\n",
    "    )\n",
    "\n",
    "    model.fit(X_train, y_train)\n",
    "\n",
    "    pred = model.predict(X_test)\n",
    "    probas = model.predict_proba(X_test)\n",
    "\n",
    "    top1_acc = accuracy_score(y_test, pred)\n",
    "    top3_acc = top_k_accuracy_score_custom(y_test, probas, k=3)\n",
    "    macro_f1 = f1_score(y_test, pred, average=\"macro\")\n",
    "\n",
    "    print(\"Top-1 Accuracy:\", round(top1_acc, 4))\n",
    "    print(\"Top-3 Accuracy:\", round(top3_acc, 4))\n",
    "    print(\"Macro F1      :\", round(macro_f1, 4))\n",
    "\n",
    "    category_models[cat] = {\n",
    "        \"model\": model,\n",
    "        \"encoder\": disease_encoder_sub,\n",
    "        \"features\": X_sub.columns.tolist(),\n",
    "        \"filtered_rows\": n_rows_filtered,\n",
    "        \"filtered_diseases\": n_diseases_filtered\n",
    "    }\n",
    "\n",
    "    category_reports.append({\n",
    "        \"category\": cat,\n",
    "        \"rows_raw\": n_rows,\n",
    "        \"diseases_raw\": n_diseases_raw,\n",
    "        \"rows_filtered\": n_rows_filtered,\n",
    "        \"diseases_filtered\": n_diseases_filtered,\n",
    "        \"top1_accuracy\": top1_acc,\n",
    "        \"top3_accuracy\": top3_acc,\n",
    "        \"macro_f1\": macro_f1\n",
    "    })\n",
    "\n",
    "category_report_df = pd.DataFrame(category_reports).sort_values(\n",
    "    by=\"top1_accuracy\",\n",
    "    ascending=False\n",
    ")\n",
    "\n",
    "category_report_df"
   ]
  },
