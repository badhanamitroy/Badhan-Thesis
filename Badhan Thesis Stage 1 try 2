    "# Top-k disease prediction inside category\n",
    "# ============================================\n",
    "\n",
    "def get_top_k_diseases(model, encoder, X_input, k=3):\n",
    "    probs = model.predict_proba(X_input)\n",
    "    top_k_idx = probs[0].argsort()[-k:][::-1]\n",
    "\n",
    "    results = []\n",
    "    for i in top_k_idx:\n",
    "        disease_name = encoder.inverse_transform([i])[0]\n",
    "        disease_prob = probs[0][i]\n",
    "        results.append((disease_name, float(disease_prob)))\n",
    "\n",
    "    return results"
   ]
