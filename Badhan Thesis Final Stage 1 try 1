    "# ===================================\n",
    "# BLOCK 13 — LIGHTGBM (OPTIMIZED)\n",
    "# ===================================\n",
    "\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "import numpy as np\n",
    "import lightgbm as lgb\n",
    "from tqdm import tqdm\n",
    "from sklearn.metrics import accuracy_score, f1_score, precision_score, recall_score\n",
    "from sklearn.utils.class_weight import compute_class_weight\n",
    "from sklearn.model_selection import train_test_split\n",
    "import time\n",
    "\n",
    "# -----------------------\n",
    "# Storage\n",
    "# -----------------------\n",
    "lgb_acc, lgb_macro, lgb_precision, lgb_recall = [], [], [], []\n",
    "lgb_overfit, lgb_time = [], []\n",
    "\n",
    "print(\"⚡ Running Optimized LightGBM (5-Fold CV)\\n\")\n",
    "\n",
    "# -----------------------\n",
    "# CV Loop\n",
    "# -----------------------\n",
    "for fold, (train_idx, test_idx) in enumerate(\n",
    "    tqdm(skf.split(np.zeros(len(y_exp_encoded)), y_exp_encoded))\n",
    "):\n",
    "\n",
    "    # 🔥 DEBUG SWITCH (remove later)\n",
    "    # if fold > 0:\n",
    "    #     break\n",
    "\n",
    "    X_train_outer = X_exp_float[train_idx]\n",
    "    X_test = X_exp_float[test_idx]\n",
    "\n",
    "    y_train_outer = y_exp_encoded[train_idx]\n",
    "    y_test = y_exp_encoded[test_idx]\n",
    "\n",
    "    # -----------------------\n",
    "    # Validation Split\n",
    "    # -----------------------\n",
    "    X_train, X_val, y_train, y_val = train_test_split(\n",
    "        X_train_outer,\n",
    "        y_train_outer,\n",
    "        test_size=0.1,\n",
    "        stratify=y_train_outer,\n",
    "        random_state=42\n",
    "    )\n",
    "\n",
    "    # -----------------------\n",
    "    # Class Weights (vectorized)\n",
    "    # -----------------------\n",
    "    classes = np.unique(y_train)\n",
    "    class_w = compute_class_weight(\"balanced\", classes=classes, y=y_train)\n",
    "    class_weight_map = dict(zip(classes, class_w))\n",
    "    sample_weights = np.vectorize(class_weight_map.get)(y_train)\n",
    "\n",
    "    # -----------------------\n",
    "    # OPTIMIZED MODEL\n",
    "    # -----------------------\n",
    "    model = lgb.LGBMClassifier(\n",
    "        objective=\"multiclass\",\n",
    "        num_class=len(le_exp.classes_),\n",
    "\n",
    "        # ⚡ SPEED CORE\n",
    "        n_estimators=800,          # ↓ from 3000\n",
    "        learning_rate=0.07,        # ↑ faster learning\n",
    "\n",
    "        # ⚖️ COMPLEXITY CONTROL\n",
    "        num_leaves=63,\n",
    "        max_depth=8,\n",
    "\n",
    "        # 🧠 GENERALIZATION\n",
    "        subsample=0.8,\n",
    "        colsample_bytree=0.8,\n",
    "\n",
    "        # 🛡️ REGULARIZATION\n",
    "        reg_lambda=1.0,\n",
    "        reg_alpha=0.2,\n",
    "        min_child_samples=40,\n",
    "\n",
    "        # ⚡ CPU (FASTER HERE)\n",
    "        device=\"cpu\",\n",
    "\n",
    "        verbosity=-1,\n",
    "        n_jobs=-1\n",
    "    )\n",
    "\n",
    "    # -----------------------\n",
    "    # TRAIN\n",
    "    # -----------------------\n",
    "    start = time.time()\n",
    "\n",
    "    model.fit(\n",
    "        X_train,\n",
    "        y_train,\n",
    "        sample_weight=sample_weights,\n",
    "        eval_set=[(X_val, y_val)],\n",
    "        eval_metric=\"multi_logloss\",\n",
    "        callbacks=[\n",
    "            lgb.early_stopping(30),     # faster stop\n",
    "            lgb.log_evaluation(100)     # minimal visibility\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    train_time = time.time() - start\n",
    "\n",
    "    # -----------------------\n",
    "    # PREDICT\n",
    "    # -----------------------\n",
    "    preds = model.predict(X_test)\n",
    "\n",
    "    acc = accuracy_score(y_test, preds)\n",
    "    macro = f1_score(y_test, preds, average=\"macro\")\n",
    "    precision = precision_score(y_test, preds, average=\"macro\", zero_division=0)\n",
    "    recall = recall_score(y_test, preds, average=\"macro\", zero_division=0)\n",
    "\n",
    "    # -----------------------\n",
    "    # OVERFIT CHECK\n",
    "    # -----------------------\n",
    "    train_preds = model.predict(X_train)\n",
    "    train_acc = accuracy_score(y_train, train_preds)\n",
    "    overfit_gap = train_acc - acc\n",
    "\n",
    "    # -----------------------\n",
    "    # STORE\n",
    "    # -----------------------\n",
    "    lgb_acc.append(acc)\n",
    "    lgb_macro.append(macro)\n",
    "    lgb_precision.append(precision)\n",
    "    lgb_recall.append(recall)\n",
    "    lgb_overfit.append(overfit_gap)\n",
    "    lgb_time.append(train_time)\n",
    "\n",
    "    print(f\"\\n🔥 Fold {fold+1}\")\n",
    "    print(\"Best Iter:\", model.best_iteration_)\n",
    "    print(\"Acc:\", acc, \"| F1:\", macro)\n",
    "    print(\"Overfit Gap:\", overfit_gap)\n",
    "    print(\"Time:\", train_time)\n",
    "\n",
    "# -----------------------\n",
    "# FINAL\n",
    "# -----------------------\n",
    "print(\"\\n===== FINAL RESULTS =====\")\n",
    "\n",
    "print(\"Avg Accuracy:\", np.mean(lgb_acc))\n",
    "print(\"Avg Macro F1:\", np.mean(lgb_macro))\n",
    "print(\"Avg Precision:\", np.mean(lgb_precision))\n",
    "print(\"Avg Recall:\", np.mean(lgb_recall))\n",
    "print(\"Avg Time:\", np.mean(lgb_time))\n",
    "print(\"Avg Overfit:\", np.mean(lgb_overfit))"
   ]
