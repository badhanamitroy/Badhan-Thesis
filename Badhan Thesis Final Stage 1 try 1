    "# ==============================\n",
    "# BLOCK 2 — CLEAN COLUMN NAMES\n",
    "# ==============================\n",
    "\n",
    "df = df_raw.copy()\n",
    "\n",
    "# Normalize column names\n",
    "df.columns = (\n",
