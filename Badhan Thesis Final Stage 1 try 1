    "# ==============================================\n",
    "# BLOCK 3 — EXTENDED DATA INTEGRITY CHECK\n",
    "# ==============================================\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "print(\"=== 1. BASIC MATRIX HEALTH ===\")\n",
    "\n",
    "# 1. Check for non-binary values cleanly (Warning-free)\n",
    "non_binary_count = (~X.isin([0, 1])).sum().sum()\n",
    "if non_binary_count == 0:\n",
    "    print(\"✅ All values are correctly binary (0 or 1).\")\n",
    "else:\n",
    "    print(f\"❌ Found {non_binary_count} non-binary values!\")\n",
    "\n",
    "# 2. Check for empty rows (Patients with zero symptoms)\n",
    "empty_rows = (X.sum(axis=1) == 0).sum()\n",
    "if empty_rows == 0:\n",
    "    print(\"✅ No empty rows found.\")\n",
    "else:\n",
    "    print(f\"⚠️ Patients with ZERO symptoms recorded: {empty_rows}\")\n",
    "\n",
    "\n",
    "print(\"\\n=== 2. SYMPTOM (FEATURE) STATS ===\")\n",
    "\n",
    "# 1. Total symptoms\n",
    "print(f\"Total Unique Symptoms: {X.shape[1]}\")\n",
    "\n",
    "# 2. Duplicate symptom names\n",
    "dup_cols = X.columns.duplicated().sum()\n",
    "print(f\"Duplicate Column Names: {dup_cols}\")\n",
    "\n",
    "# 3. Constant symptoms (Always 0 or Always 1)\n",
    "constant_cols = (X.nunique() <= 1).sum()\n",
    "print(f\"⚠️ Constant Symptoms (Zero Variance): {constant_cols}\")\n",
    "\n",
    "# 4. Rare symptoms\n",
    "symptom_frequencies = X.sum(axis=0)\n",
